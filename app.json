{
  "expo": {
    "name": "Safeco Taxi Service",
    "slug": "taxitrack-png",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/play_store/icon_main_512x512.png",
    "scheme": "taxitrackpng",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.skyworks.taxitrackpng",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/launcher/adaptive-foreground_1024.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/launcher/icon_mdpi_48x48.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/play_store/icon_main_512x512.png",
          "imageWidth": 180
        }
      ],
      "expo-font",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5b5a9e25-700b-4b17-a5af-6a83ce5d7143"
      }
    },
    "owner": "andykiap"
  }
}
